  <!-- ====== Proxy del generador de hojas de vida ====== -->
  <!-- Reenvía /api/cv/* al backend que escucha en localhost:3001. No requiere
       configuración: el backend solo acepta conexiones desde el propio servidor
       y este servlet se limita a reenviar la petición.
       El parámetro 'format' no se valida aquí, de modo que añadir un formato
       nuevo solo implica cambiar el backend, sin recompilar Java. -->
  <servlet>
    <servlet-name>CVProxyServlet</servlet-name>
    <servlet-class>co.edu.urosario.hubur.CVProxyServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>CVProxyServlet</servlet-name>
    <url-pattern>/api/cv/*</url-pattern>
  </servlet-mapping>


