# ============================================================
# Backend de Hojas de Vida — configuración
# ============================================================
# Copia este archivo como .env en el servidor y ajusta las rutas.
# .env está listado en .gitignore y no debe versionarse.
# ============================================================

# --- Servicios locales ---
SOLR_URL=http://localhost:8983/solr/vivocore/select
VIVO_BASE_URL=http://localhost:8080
PORT=3001

# Interfaz en la que escucha el servidor. Se deja en loopback para que solo
# los procesos del propio servidor puedan alcanzarlo; el acceso desde el
# navegador entra por el proxy de Tomcat (/api/cv/*).
# Cambiarlo a 0.0.0.0 expondría el servicio a la red SIN autenticación.
BIND_HOST=127.0.0.1

# --- Rutas de plantillas y LibreOffice (servidor Linux) ---
SOFFICE_PATH=/home/admincrai/lo7/opt/libreoffice7.6/program/soffice
HARVARD_TEMPLATE="/home/admincrai/cv-generator/03-assets/2025-template_bullet (3).docx"
EUROPASS_TEMPLATE=/home/admincrai/cv-generator/03-assets/europass_template.pdf
EUROPASS_LOGO=/home/admincrai/cv-generator/03-assets/europass_logo.png

# --- Caché y límites ---
CACHE_TTL=300
MAX_CACHE_ENTRIES=200
MAX_RETRIES=3
RETRY_BACKOFF=0.5,1.0,2.0

# Peticiones por minuto y por IP. No es una medida de seguridad: evita que
# varias generaciones simultáneas saturen LibreOffice, que es costoso.
CV_RATE_LIMIT=5
CV_RATE_WINDOW=60

# --- CORS (solo el origen de Tomcat) ---
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
